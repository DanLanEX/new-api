# New API personal lightweight environment
# GPT注：这是给 docker-compose.yml 的轻量 SQLite 单容器部署使用的环境模板。
# GPT注：使用时可以复制为 .env：cp my.env .env，然后修改 SESSION_SECRET 和域名相关配置。
# GPT注：不要把真实 .env 提交到 Git；my.env 只放模板值。

# -----------------------------------------------------------------------------
# Basic
# -----------------------------------------------------------------------------

# GPT注：容器内服务端口。docker-compose.yml 已经把宿主机 127.0.0.1:3000 映射到容器 3000，一般不用改。
PORT=3000

# GPT注：服务公开访问域名。接 Caddy / Nginx 反代后建议填写，例如 https://newapi.example.com。
# GPT注：没绑定域名或只本机访问时可以先留空。
FRONTEND_BASE_URL=

# GPT注：必须改成固定随机字符串；不要使用 random_string，不要每次启动都变化。
# GPT注：生成方式示例：openssl rand -hex 32
SESSION_SECRET=CHANGE_THIS_TO_A_FIXED_RANDOM_STRING

# GPT注：SQLite 数据库文件位置；与 docker-compose.yml 的 ./data:/data 挂载对应。
SQLITE_PATH=/data/new-api.db

# GPT注：时区。个人部署按国内使用习惯保留 Asia/Shanghai。
TZ=Asia/Shanghai

# -----------------------------------------------------------------------------
# Logs and diagnostics
# -----------------------------------------------------------------------------

# GPT注：建议开启，方便排查上游模型、网关转发、客户端调用错误。
ERROR_LOG_ENABLED=true

# GPT注：默认关闭调试模式；打开会输出更多信息，不适合长期公网运行。
# DEBUG=true

# GPT注：性能分析接口，默认关闭；除非你要定位 Go 性能问题，否则不要开。
# ENABLE_PPROF=true

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

# GPT注：轻量 SQLite 部署不要设置 SQL_DSN；不设置时源码会自动使用 SQLite。
# SQL_DSN=

# GPT注：日志库单独存储才需要；轻量自用不需要。
# LOG_SQL_DSN=

# GPT注：SQLite 单人自用通常不需要调这些连接池参数。
# SQL_MAX_IDLE_CONNS=100
# SQL_MAX_OPEN_CONNS=1000
# SQL_MAX_LIFETIME=60

# -----------------------------------------------------------------------------
# Redis and cache
# -----------------------------------------------------------------------------

# GPT注：轻量单容器部署不要设置 REDIS_CONN_STRING；不设置时 Redis 会自动关闭。
# REDIS_CONN_STRING=

# GPT注：无 Redis 时通常不需要内存缓存；渠道很多、想减少数据库读取时再打开。
# MEMORY_CACHE_ENABLED=true

# GPT注：缓存/配置同步频率，打开 MEMORY_CACHE_ENABLED 或多节点时再考虑。
# SYNC_FREQUENCY=60

# GPT注：渠道自动更新频率。自用先关闭，避免后台任务额外复杂度。
# CHANNEL_UPDATE_FREQUENCY=30

# GPT注：批量更新任务。SQLite 自用先关闭；需要异步任务批量同步时再打开。
# BATCH_UPDATE_ENABLED=true
# BATCH_UPDATE_INTERVAL=5

# -----------------------------------------------------------------------------
# Relay timeout
# -----------------------------------------------------------------------------

# GPT注：整体请求超时，0 表示不限制。一般保持默认即可。
# RELAY_TIMEOUT=0

# GPT注：Relay HTTP 客户端空闲连接超时，默认 90 秒通常够用。
# RELAY_IDLE_CONN_TIMEOUT=90

# GPT注：流式响应无数据超时。遇到长思考模型、空补全、断流时可调大。
STREAMING_TIMEOUT=300

# -----------------------------------------------------------------------------
# Security and compatibility
# -----------------------------------------------------------------------------

# GPT注：不要打开 TLS 跳过验证，除非你明确知道上游证书异常且接受风险。
TLS_INSECURE_SKIP_VERIFY=false

# GPT注：Gemini 单次识别图片数量上限；默认 16 通常够用。
# GEMINI_VISION_MAX_IMAGE_NUM=16

# GPT注：生成默认 token 默认关闭更安全；首次登录后台后自己创建 token。
GENERATE_DEFAULT_TOKEN=false

# GPT注：媒体 token 统计建议保留开启，方便图片/多模态计费统计。
GET_MEDIA_TOKEN=true

# GPT注：非流式请求是否统计媒体 token。默认关闭，避免额外开销。
GET_MEDIA_TOKEN_NOT_STREAM=false

# GPT注：Dify 渠道是否把工作流和节点信息输出给客户端。自用调试可开；不想暴露细节可关。
DIFY_DEBUG=true

# GPT注：Cohere 安全设置，使用 Cohere/Rerank 时再关注。
# COHERE_SAFETY_SETTING=NONE

# -----------------------------------------------------------------------------
# OAuth / LinuxDo
# -----------------------------------------------------------------------------

# GPT注：保留官方默认 LinuxDo OAuth 地址；不用 LinuxDo 登录也没关系。
LINUX_DO_TOKEN_ENDPOINT=https://connect.linux.do/oauth2/token
LINUX_DO_USER_ENDPOINT=https://connect.linux.do/api/user

# -----------------------------------------------------------------------------
# Node mode
# -----------------------------------------------------------------------------

# GPT注：单节点默认就是主节点，不需要设置。多节点部署时再区分 master/slave。
# NODE_TYPE=master

# GPT注：节点名用于审计日志；单节点无所谓，多节点再设置。
# NODE_NAME=new-api-node-1

# -----------------------------------------------------------------------------
# Redirect domain allowlist
# -----------------------------------------------------------------------------

# GPT注：如果你启用支付、OAuth 回调或外部跳转，建议填可信域名，降低开放重定向风险。
# GPT注：例如：TRUSTED_REDIRECT_DOMAINS=example.com,newapi.example.com
TRUSTED_REDIRECT_DOMAINS=

# -----------------------------------------------------------------------------
# Analytics
# -----------------------------------------------------------------------------

# GPT注：站点统计。不需要就保持空。
# GOOGLE_ANALYTICS_ID=
# UMAMI_WEBSITE_ID=
# UMAMI_SCRIPT_URL=https://analytics.umami.is/script.js
